{
  "id": "dnd5e-calendar",
  "title": "DnD5e Calendar & Time Tracker",
  "description": "A fully editable in-game calendar with time tracking, seasons, weather, moon phases, day/night cycles, and holiday management for DnD5e.",
  "author": "Null8Void",
  "version": "1.0.0",
  "compatibility": {
    "minimum": "11",
    "verified": "14",
    "maximum": "14.*"
  },
  "manifestPlusVersion": 1,
  "url": "https://github.com/Null8Void/dnd5e-calendar",
  "manifest": "https://raw.githubusercontent.com/Null8Void/dnd5e-calendar/master/module.json",
  "download": "https://github.com/Null8Void/dnd5e-calendar/archive/master.zip",
  "readme": "README.md",
  "bugs": "https://github.com/Null8Void/dnd5e-calendar/issues",
  "changelog": "https://github.com/Null8Void/dnd5e-calendar/releases",
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "esmodules": [
    "scripts/main.js"
  ],
  "scripts": [
    "scripts/main.js",
    "scripts/calendar-data.js",
    "scripts/calendar-constants.js",
    "scripts/calendar-manager.js",
    "scripts/calendar-hud.js",
    "scripts/calendar-config.js",
    "scripts/calendar-api.js",
    "scripts/calendar-utils.js",
    "scripts/calendar-permissions.js",
    "scripts/calendar-debug.js",
    "scripts/moon-phase-manager.js",
    "scripts/weather-manager.js",
    "scripts/season-manager.js",
    "scripts/day-night-manager.js",
    "scripts/holiday-manager.js",
    "scripts/holiday-submit-dialog.js",
    "scripts/holiday-approval-panel.js"
  ],
  "styles": [
    "styles/calendar.css"
  ],
  "packs": [],
  "systems": [
    {
      "id": "dnd5e",
      "type": "system",
      "compatibility": {
        "minimum": "3.0.0",
        "verified": "5.3.0",
        "maximum": "5.*"
      }
    }
  ],
  "dependencies": [],
  "flags": {}
}
